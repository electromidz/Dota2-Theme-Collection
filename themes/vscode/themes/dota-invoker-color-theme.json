  "tokenColors": [
    {
      "name": "Comments",
      "scope": [
        "comment",
        "punctuation.definition.comment"
      ],
      "settings": {
        "foreground": "#6a5fad",
        "fontStyle": "italic"
      }
    },
    {
      "name": "Strings",
      "scope": [
        "string",
        "string.quoted"
      ],
      "settings": {
        "foreground": "#d1c4e9"
      }
    },
    {
      "name": "Numbers",
      "scope": [
        "constant.numeric"
      ],
      "settings": {
        "foreground": "#ea80fc"
      }
    },
    {
      "name": "Boolean",
      "scope": [
        "constant.language"
      ],
      "settings": {
        "foreground": "#ea80fc"
      }
    },
    {
      "name": "Keywords",
      "scope": [
        "keyword",
        "keyword.control",
        "keyword.operator.new",
        "keyword.operator.expression"
      ],
      "settings": {
        "foreground": "#b388ff"
      }
    },
    {
      "name": "Storage",
      "scope": [
        "storage",
        "storage.type"
      ],
      "settings": {
        "foreground": "#b388ff"
      }
    },
    {
      "name": "Functions",
      "scope": [
        "entity.name.function",
        "support.function",
        "meta.function-call"
      ],
      "settings": {
        "foreground": "#7c4dff"
      }
    },
    {
      "name": "Classes",
      "scope": [
        "entity.name.type",
        "entity.name.class",
        "support.type",
        "support.class"
      ],
      "settings": {
        "foreground": "#b388ff"
      }
    },
    {
      "name": "Interfaces",
      "scope": [
        "entity.name.type.interface"
      ],
      "settings": {
        "foreground": "#b388ff"
      }
    },
    {
      "name": "Enums",
      "scope": [
        "entity.name.type.enum",
        "variable.other.enummember"
      ],
      "settings": {
        "foreground": "#d1c4e9"
      }
    },
    {
      "name": "Variables",
      "scope": [
        "variable",
        "variable.other"
      ],
      "settings": {
        "foreground": "#d4ccec"
      }
    },
    {
      "name": "Parameters",
      "scope": [
        "variable.parameter"
      ],
      "settings": {
        "foreground": "#d4ccec"
      }
    },
    {
      "name": "Properties",
      "scope": [
        "variable.other.property",
        "support.variable.property"
      ],
      "settings": {
        "foreground": "#b388ff"
      }
    },
    {
      "name": "Constants",
      "scope": [
        "variable.other.constant",
        "variable.language"
      ],
      "settings": {
        "foreground": "#ea80fc"
      }
    },
    {
      "name": "Operators",
      "scope": [
        "keyword.operator"
      ],
      "settings": {
        "foreground": "#b388ff"
      }
    },
    {
      "name": "Punctuation",
      "scope": [
        "punctuation",
        "meta.brace"
      ],
      "settings": {
        "foreground": "#6a5fad"
      }
    },
    {
      "name": "Tags",
      "scope": [
        "entity.name.tag"
      ],
      "settings": {
        "foreground": "#7c4dff"
      }
    },
    {
      "name": "Attributes",
      "scope": [
        "entity.other.attribute-name"
      ],
      "settings": {
        "foreground": "#b388ff"
      }
    },
    {
      "name": "Decorators",
      "scope": [
        "meta.decorator",
        "punctuation.decorator"
      ],
      "settings": {
        "foreground": "#ea80fc"
      }
    },
    {
      "name": "Builtins",
      "scope": [
        "support.constant",
        "support.variable"
      ],
      "settings": {
        "foreground": "#b388ff"
      }
    },
    {
      "name": "Regex",
      "scope": [
        "string.regexp"
      ],
      "settings": {
        "foreground": "#ea80fc"
      }
    },
    {
      "name": "Escape Chars",
      "scope": [
        "constant.character.escape"
      ],
      "settings": {
        "foreground": "#ea80fc"
      }
    }
  ]
}